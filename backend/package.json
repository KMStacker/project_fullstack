{
  "name": "backend",
  "version": "1.0.0",
  "main": "build/index.js",
  "scripts": {
    "test": "cross-env NODE_ENV=test jest --verbose --runInBand --forceExit",
    "start": "cross-env NODE_ENV=production node build/createAdminAccount.js && cross-env NODE_ENV=production node build/seedDatabase.js && cross-env NODE_ENV=production node build/index.js",
    "dev": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only index.ts",
    "start:test": "cross-env NODE_ENV=test ts-node createAdminAccount.ts && cross-env NODE_ENV=test ts-node seedDatabase.ts && cross-env NODE_ENV=test ts-node-dev --transpile-only index.ts",
    "lint": "eslint .",
    "build": "tsc",
    "create-admin": "cross-env NODE_ENV=development ts-node createAdminAccount.ts",
    "seed-db": "cross-env NODE_ENV=development ts-node seedDatabase.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cross-env": "^10.0.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.17.0",
    "pg": "^8.22.0",
    "sequelize": "^6.37.8",
    "umzug": "^3.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.21",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.38.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
